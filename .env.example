# Added by Payload
PAYLOAD_SECRET=
# Local dev DB. In Vercel prod env vars, set this to the Neon connection string instead.
DATABASE_URL=

# RapidAPI "instagram120" — used by the Reels collection's "Sync reels" admin button
RAPIDAPI_KEY=

# Cloudflare R2 (S3-compatible media storage). Leave blank for local dev —
# Media falls back to local disk storage when R2_BUCKET is unset.
# Fill these in (and set them as Vercel prod env vars) once the R2 bucket exists.
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=